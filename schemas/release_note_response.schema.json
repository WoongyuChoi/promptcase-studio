{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://promptcase-studio.local/schemas/release_note_response-1.0.0.json",
  "title": "Promptcase Studio Release Note Mail",
  "description": "팀 공유용 한국어 릴리즈 안내 메일 계약",
  "type": "object",
  "additionalProperties": false,
  "required": ["subject", "body"],
  "properties": {
    "subject": {
      "type": "string",
      "minLength": 8,
      "maxLength": 120,
      "pattern": "^[^\\r\\n]+$"
    },
    "body": {
      "type": "string",
      "minLength": 120,
      "maxLength": 5000,
      "pattern": "^안녕하세요[\\s\\S]*감사합니다[.!]?$"
    }
  }
}
