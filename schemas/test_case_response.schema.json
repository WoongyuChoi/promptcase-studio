{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://promptcase-studio.local/schemas/test_case_response-2.2.0.json",
  "title": "Promptcase Studio Unit Test Response",
  "description": "사람이 작성한 형태의 한국어 단위테스트 문안 계약",
  "type": "object",
  "additionalProperties": false,
  "required": ["testCase", "testResult"],
  "properties": {
    "documentTitle": {
      "description": "확장자와 날짜를 제외한 짧은 시스템명이며 기존 응답 호환을 위해 선택 필드로 유지한다",
      "type": "string",
      "maxLength": 40,
      "pattern": "^(?!.$)(?!.*(?:단위\\s*테스트|[.]xlsx|(?:19|20)[0-9]{2}[-_.]?[0-9]{2}[-_.]?[0-9]{2}|[0-9]{6,8}))(?!.*[()（）])(?!.*[.,!?;:。，！？]$)[^\\r\\n\\u005c:;：；·ㆍ‧∙⋅○●•◦▪▫◆◇▶▷■□※★☆♥♡♠♣\\\"'“”‘’「」『』＂＇`*#><\\[\\]{}|~]*$"
    },
    "testCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "procedure",
        "targetIds",
        "targetNames",
        "preconditions",
        "testData",
        "expectedResult",
        "notes"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 6,
          "maxLength": 100,
          "pattern": "^(?!\\s*(?:[-*#]|[0-9]+[.)]))(?=[^\\r\\n]*단위테스트$)[^\\r\\n\\u005c:;：；·ㆍ‧∙⋅○●•◦▪▫◆◇▶▷■□※★☆♥♡♠♣\\\"'“”‘’「」『』＂＇`*#><\\[\\]{}|~]+$"
        },
        "procedure": {
          "description": "변경 규모와 사용자 흐름에 맞춘 1개 이상 5개 이하의 실제 실행 단계",
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 8,
            "maxLength": 160,
            "pattern": "^(?!\\s*(?:[-*#]|[0-9]+[.)]))(?=[^\\r\\n]*다$)[^\\r\\n\\u005c:;：；·ㆍ‧∙⋅○●•◦▪▫◆◇▶▷■□※★☆♥♡♠♣\\\"'“”‘’「」『』＂＇`*#><\\[\\]{}|~]+$"
          }
        },
        "targetIds": {
          "type": "array",
          "maxItems": 12,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 80,
            "pattern": "^[A-Za-z0-9가-힣_./\\\\:#$=@<>~\\[\\]-]+$"
          }
        },
        "targetNames": {
          "type": "array",
          "maxItems": 12,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100,
            "pattern": "^(?!\\s*(?:[-*#]|[0-9]+[.)]))(?!.*[.,!?;:。，！？]$)[^\\r\\n\\u005c:;：；·ㆍ‧∙⋅○●•◦▪▫◆◇▶▷■□※★☆♥♡♠♣\\\"'“”‘’「」『』＂＇`*#><\\[\\]{}|~]+$"
          }
        },
        "preconditions": {
          "description": "테스트 실행에 실제로 필요한 0개 이상 5개 이하의 준비 조건",
          "type": "array",
          "minItems": 0,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 8,
            "maxLength": 160,
            "pattern": "^(?!\\s*(?:[-*#]|[0-9]+[.)]))(?=[^\\r\\n]*다$)[^\\r\\n\\u005c:;：；·ㆍ‧∙⋅○●•◦▪▫◆◇▶▷■□※★☆♥♡♠♣\\\"'“”‘’「」『』＂＇`*#><\\[\\]{}|~]+$"
          }
        },
        "testData": {
          "description": "필요할 때 식별 가능한 값을 한국어 조사와 쉼표로 자연스럽게 연결한 한 문장이며 별도 데이터가 없으면 빈 문자열",
          "type": "string",
          "minLength": 0,
          "maxLength": 180,
          "pattern": "^(?:$|(?!\\s*(?:[-*#]|[0-9]+[.)]))(?=[^\\r\\n]*다$)[^\\r\\n\\u005c:;：；·ㆍ‧∙⋅○●•◦▪▫◆◇▶▷■□※★☆♥♡♠♣\\\"'“”‘’「」『』＂＇`*#><\\[\\]{}|~]+)$"
        },
        "expectedResult": {
          "description": "하나 또는 서로 직접 연결된 두 개의 관찰 결과를 간결하게 합친 한 문장",
          "type": "string",
          "minLength": 10,
          "maxLength": 180,
          "pattern": "^(?!\\s*(?:[-*#]|[0-9]+[.)]))(?=[^\\r\\n]*다$)[^\\r\\n\\u005c:;：；·ㆍ‧∙⋅○●•◦▪▫◆◇▶▷■□※★☆♥♡♠♣\\\"'“”‘’「」『』＂＇`*#><\\[\\]{}|~]+$"
        },
        "notes": {
          "type": "string",
          "maxLength": 300,
          "pattern": "^(?!.$)(?!\\s*(?:[-*#]|[0-9]+[.)]))(?!.*[.,!?;:。，！？]$)[^\\r\\n\\u005c:;：；·ㆍ‧∙⋅○●•◦▪▫◆◇▶▷■□※★☆♥♡♠♣\\\"'“”‘’「」『』＂＇`*#><\\[\\]{}|~]*$"
        }
      }
    },
    "testResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["processingDetails", "testDetails", "resultChecks"],
      "properties": {
        "processingDetails": {
          "description": "파일 목록이 아닌 핵심 변경 주제 1개 이상 5개 이하",
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "detail"],
            "properties": {
              "title": {
                "type": "string",
                "minLength": 3,
                "maxLength": 80,
                "pattern": "^(?!\\s*(?:[-*#]|[0-9]+[.)]))(?!.*[.,!?;:。，！？]$)[^\\r\\n\\u005c:;：；·ㆍ‧∙⋅○●•◦▪▫◆◇▶▷■□※★☆♥♡♠♣\\\"'“”‘’「」『』＂＇`*#><\\[\\]{}|~]+$"
              },
              "detail": {
                "type": "string",
                "minLength": 6,
                "maxLength": 160,
                "pattern": "^(?!\\s*(?:[-*#]|[0-9]+[.)]))(?!.*[.,!?;:。，！？]$)[^\\r\\n\\u005c:;：；·ㆍ‧∙⋅○●•◦▪▫◆◇▶▷■□※★☆♥♡♠♣\\\"'“”‘’「」『』＂＇`*#><\\[\\]{}|~]+$"
              }
            }
          }
        },
        "testDetails": {
          "description": "procedure와 같은 수와 순서로 대응하는 1개 이상 5개 이하의 관찰 결과",
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 8,
            "maxLength": 160,
            "pattern": "^(?!\\s*(?:[-*#]|[0-9]+[.)]))(?=[^\\r\\n]*다$)[^\\r\\n\\u005c:;：；·ㆍ‧∙⋅○●•◦▪▫◆◇▶▷■□※★☆♥♡♠♣\\\"'“”‘’「」『』＂＇`*#><\\[\\]{}|~]+$"
          }
        },
        "resultChecks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 5,
            "maxLength": 120,
            "pattern": "^(?!\\s*(?:[-*#]|[0-9]+[.)]))(?!.*[.,!?;:。，！？]$)[^\\r\\n\\u005c:;：；·ㆍ‧∙⋅○●•◦▪▫◆◇▶▷■□※★☆♥♡♠♣\\\"'“”‘’「」『』＂＇`*#><\\[\\]{}|~]+$"
          }
        }
      }
    }
  }
}
