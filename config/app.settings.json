{
  "schemaVersion": 1,
  "defaultEnvironment": "secure",
  "templatePath": "templates/unittest_template.xlsx",
  "outputDirectory": "outputs",
  "runDirectory": "runs",
  "mockMode": false,
  "responseValidationAttempts": 3,
  "releaseNoteValidationAttempts": 2,
  "qualityReviewEnabled": true,
  "qualityReviewPasses": 2,
  "qualityReviewValidationAttempts": 2,
  "qualityGateMode": "best_effort",
  "providers": {
    "online": {
      "type": "gemini",
      "apiBase": "https://generativelanguage.googleapis.com/v1beta",
      "model": "auto",
      "fallbackModels": [
        "gemini-3.5-flash",
        "gemini-3.5-flash-lite",
        "gemini-3.1-flash-lite"
      ],
      "apiKeyEnv": "GEMINI_API_KEY",
      "timeoutSeconds": 300,
      "maxAttempts": 3,
      "retryDelaySeconds": 2,
      "maxOutputTokens": 32768
    },
    "secure": {
      "type": "qwen",
      "settingsPath": "config/qwen.settings.json",
      "timeoutSeconds": 300,
      "maxAttempts": 3,
      "retryDelaySeconds": 2,
      "maxOutputTokens": 32768,
      "stream": true
    }
  },
  "scanner": {
    "maxCandidateFiles": 20000,
    "maxChangedFileChars": 48000,
    "maxRelatedFiles": 32,
    "maxRelatedFileChars": 16000,
    "relatedContextRatio": 0.25,
    "maxContextChars": 360000,
    "maxDiffChars": 32000,
    "maxSelectedCommits": 3,
    "maxSelectedFiles": 24,
    "commitEvidenceShortlist": 12,
    "maxCommitEvidenceChars": 40000,
    "maxContentScanFiles": 10000,
    "maxSourceScanChars": 320000
  },
  "prompt": {
    "maxPromptChars": 420000,
    "releaseNoteMaxPromptChars": 100000,
    "maxRequestChars": 24000,
    "maxManifestChars": 48000,
    "maxChangeNotesChars": 16000,
    "reviewReserveChars": 24000
  }
}
