{
  "schemaVersion": 1,
  "defaultEnvironment": "online",
  "templatePath": "templates/단위테스트 템플릿.xlsx",
  "outputDirectory": "outputs",
  "runDirectory": "runs",
  "mockMode": false,
  "responseValidationAttempts": 3,
  "qualityReviewEnabled": true,
  "qualityReviewPasses": 2,
  "qualityReviewValidationAttempts": 2,
  "providers": {
    "online": {
      "type": "gemini",
      "apiBase": "https://generativelanguage.googleapis.com/v1beta",
      "model": "gemini-flash-latest",
      "apiKeyEnv": "GEMINI_API_KEY",
      "timeoutSeconds": 300,
      "maxAttempts": 3,
      "retryDelaySeconds": 2,
      "maxOutputTokens": 32768
    },
    "secure": {
      "type": "qwen",
      "settingsPath": "config/qwen.settings.json",
      "timeoutSeconds": 300,
      "maxAttempts": 3,
      "retryDelaySeconds": 2,
      "maxOutputTokens": 32768,
      "stream": true
    }
  },
  "scanner": {
    "maxCandidateFiles": 20000,
    "maxChangedFileChars": 48000,
    "maxRelatedFiles": 32,
    "maxRelatedFileChars": 16000,
    "relatedContextRatio": 0.25,
    "maxContextChars": 360000,
    "maxDiffChars": 32000,
    "maxContentScanFiles": 10000,
    "maxSourceScanChars": 320000
  },
  "prompt": {
    "maxPromptChars": 420000,
    "maxRequestChars": 24000,
    "maxManifestChars": 48000,
    "maxChangeNotesChars": 16000,
    "reviewReserveChars": 24000
  }
}
